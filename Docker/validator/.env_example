# Wallet Configuration (Required)
WALLET_NAME=default
HOTKEY_NAME=default

# LLM API Configuration (Optional - for narrative scoring)
# Uses OpenAI-compatible API format. Works with: OpenAI, Zhipu, vLLM, Ollama, etc.
#
# Example 1: OpenAI
# OPENAI_API_KEY=sk-xxx
#
# Example 2: Zhipu GLM (智谱)
# OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
# OPENAI_API_KEY=your_zhipu_api_key
#
# Example 3: Local vLLM/Ollama (auto-detected, no config needed)
#
# If not configured, narrative score defaults to 15/30

OPENAI_API_BASE=
OPENAI_API_KEY=